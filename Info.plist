<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- ── App ───────────────────────────────────────────────── -->
    <key>CFBundleName</key>
    <string>TwitchUnblock</string>
    <key>CFBundleDisplayName</key>
    <string>TwitchUnblock</string>
    <key>CFBundleIdentifier</key>
    <string>com.yourname.TwitchUnblock</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0.0</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>

    <!-- ── Deep Link URL Scheme (twitchunblock://) ───────────── -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>twitchunblock</string>
            </array>
            <key>CFBundleURLName</key>
            <string>com.yourname.TwitchUnblock</string>
        </dict>
    </array>

    <!-- ── Background Modes (audio + PiP) ────────────────────── -->
    <key>UIBackgroundModes</key>
    <array>
        <string>audio</string>
        <string>fetch</string>
    </array>

    <!-- ── External app URL schemes (canOpenURL whitelist) ────── -->
    <key>LSApplicationQueriesSchemes</key>
    <array>
        <string>vlc</string>
        <string>outplayer</string>
        <string>infuse</string>
    </array>

    <!-- ── Privacy ───────────────────────────────────────────── -->
    <key>NSCameraUsageDescription</key>
    <string>Cette app n'utilise pas la caméra.</string>
    <key>NSMicrophoneUsageDescription</key>
    <string>Cette app n'utilise pas le microphone.</string>

    <!-- ── ATS: allow HTTP for Twitch CDN (optional) ─────────── -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <true/>
    </dict>

    <!-- ── Orientation ────────────────────────────────────────── -->
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>

    <!-- ── Status bar ─────────────────────────────────────────── -->
    <key>UIStatusBarStyle</key>
    <string>UIStatusBarStyleLightContent</string>
    <key>UIViewControllerBasedStatusBarAppearance</key>
    <false/>

    <!-- ── Launch screen ─────────────────────────────────────── -->
    <key>UILaunchScreen</key>
    <dict/>
</dict>
</plist>
